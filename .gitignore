# app data / cache (not config)
configstore/
lzc-client-desktop/
karabiner/automatic_backups/

# git: signing key is in gitconfig, no secrets to exclude

# emacs: packages and generated files (managed by straight.el)
# only hand-written config files are tracked
emacs/straight/
emacs/var/
emacs/etc/

# emacs: server socket (runtime)
emacs/server/

# vscode: build artifacts
vscode/open-in-emacs/*.vsix

# fish: runtime state
fish/fish_variables

# fish: all plugin-generated files (managed by fisher, not hand-written)
# completions/ and conf.d/ are entirely plugin-generated
fish/completions/
fish/conf.d/
fish/themes/
# functions/: ignore everything, then whitelist hand-written files
fish/functions/*
!fish/functions/p.fish
